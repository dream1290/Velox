  <project_license>GPL-3.0-or-later</project_license>

  <name>Velox</name>
  <summary>Fast, native Ubuntu video player</summary>

  <description>
    <p>
      Velox is a video player built for Ubuntu with GTK4 and libadwaita,
      using GStreamer for media decoding and PipeWire for audio output.
    </p>
    <p>Features:</p>
    <ul>
      <li>Zero-copy video via OpenGL/EGL texture sharing</li>
      <li>Hardware-accelerated decoding (VAAPI, NVDEC)</li>
      <li>Custom seek bar with chapter marks and hover thumbnails</li>
      <li>MPRIS2 D-Bus integration (media keys, Playerctl, KDE Connect)</li>
      <li>Subtitle support: SRT, ASS, VTT</li>
      <li>Playlist with shuffle, repeat, and live directory watching</li>
      <li>Resume playback, dark mode, and adaptive layout</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.velox.desktop</launchable>

  <url type="homepage">https://github.com/velox/velox</url>
  <url type="bugtracker">https://github.com/velox/velox/issues</url>

  <provides>
    <binary>velox</binary>
  </provides>

  <releases>
    <release version="3.0.2" date="2026-06-15">
      <description>
        <p>Initial release of Velox Video Player.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>

  <requires>
